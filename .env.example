# Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://speechontheslope.com
NEXT_PUBLIC_SITE_NAME="Speech on the Slope"

# Contact Information
NEXT_PUBLIC_PHONE="+1-XXX-XXX-XXXX"
NEXT_PUBLIC_EMAIL="info@speechontheslope.com"
NEXT_PUBLIC_ADDRESS_STREET="Your Street Address"
NEXT_PUBLIC_ADDRESS_CITY="Brooklyn"
NEXT_PUBLIC_ADDRESS_STATE="NY"
NEXT_PUBLIC_ADDRESS_ZIP="XXXXX"

# Geo Coordinates (for local SEO)
NEXT_PUBLIC_LATITUDE="40.6782"
NEXT_PUBLIC_LONGITUDE="-73.9442"

# Social Media
NEXT_PUBLIC_TWITTER_HANDLE="@speechontheslope"
NEXT_PUBLIC_FACEBOOK_URL="https://facebook.com/yourpage"
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/yourpage"

# Analytics & Tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# Search Console Verification
GOOGLE_VERIFICATION_CODE="your-google-verification-code"

# Email Service (for contact form)
# SENDGRID_API_KEY="your-sendgrid-api-key"
# RESEND_API_KEY="your-resend-api-key"

# Database (if needed in future)
# DATABASE_URL="postgresql://..."

# Rate Limiting
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="your-token"
